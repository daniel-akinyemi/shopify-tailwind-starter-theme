<header class="sticky top-0 z-40 border-b border-gray-200 bg-white/90 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-4 py-4">
    {%- comment -%} Logo / shop name {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="flex shrink-0 items-center">
      {%- if settings.logo != blank -%}
        <img
          src="{{ settings.logo | image_url: width: 480 }}"
          alt="{{ shop.name | escape }}"
          width="{{ settings.logo.width }}"
          height="{{ settings.logo.height }}"
          style="width: {{ settings.logo_width }}px"
          class="h-auto"
        >
      {%- else -%}
        <span class="text-xl font-semibold tracking-tight">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    {%- comment -%} Primary navigation {%- endcomment -%}
    <nav class="hidden md:block" aria-label="Primary">
      <ul class="flex items-center gap-6">
        {%- for link in section.settings.menu.links -%}
          <li>
            <a
              href="{{ link.url }}"
              class="text-sm font-medium text-gray-700 transition-colors hover:text-brand {% if link.active %}text-brand{% endif %}"
            >
              {{ link.title }}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    {%- comment -%} Actions {%- endcomment -%}
    <div class="flex items-center gap-4">
      <a href="{{ routes.search_url }}" class="text-gray-700 hover:text-brand" aria-label="{{ 'general.search.search' | t }}">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
        </svg>
      </a>

      <a href="{{ routes.cart_url }}" class="relative text-gray-700 hover:text-brand" aria-label="{{ 'cart.title' | t }}">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="absolute -right-2 -top-2 flex h-5 min-w-5 items-center justify-center rounded-full bg-brand px-1 text-xs font-medium text-white">
            {{ cart.item_count }}
          </span>
        {%- endif -%}
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
