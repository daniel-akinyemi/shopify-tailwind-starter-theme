<section class="mx-auto max-w-7xl px-4 py-10">
  <h1 class="mb-8 text-3xl font-bold tracking-tight text-gray-900">{{ 'collections.general.all_collections' | t }}</h1>

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {%- for collection in collections -%}
      <a href="{{ collection.url }}" class="group relative overflow-hidden rounded-xl bg-gray-100">
        {%- if collection.featured_image -%}
          <img
            src="{{ collection.featured_image | image_url: width: 600 }}"
            alt="{{ collection.featured_image.alt | escape }}"
            width="{{ collection.featured_image.width }}"
            height="{{ collection.featured_image.height }}"
            loading="lazy"
            class="aspect-4/3 w-full object-cover transition-transform duration-300 group-hover:scale-105"
          >
        {%- else -%}
          <div class="flex aspect-4/3 items-center justify-center text-gray-400">
            {{ 'collection-1' | placeholder_svg_tag: 'h-1/2 w-1/2' }}
          </div>
        {%- endif -%}
        <div class="absolute inset-0 flex items-end bg-gradient-to-t from-black/60 to-transparent p-4">
          <h2 class="text-lg font-semibold text-white">{{ collection.title }}</h2>
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Collections list",
  "tag": "section",
  "settings": []
}
{% endschema %}
