<section class="mx-auto max-w-4xl px-4 py-12">
  <h1 class="mb-8 text-3xl font-bold tracking-tight text-gray-900">{{ 'cart.title' | t }}</h1>

  {%- if cart.item_count > 0 -%}
    {%- form 'cart', cart, class: 'flex flex-col gap-8' -%}
      <ul class="divide-y divide-gray-200">
        {%- for item in cart.items -%}
          <li class="flex gap-4 py-6">
            <a href="{{ item.url }}" class="shrink-0 overflow-hidden rounded-lg bg-gray-100">
              {%- if item.image -%}
                <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.image.alt | escape }}" width="{{ item.image.width }}" height="{{ item.image.height }}" class="h-24 w-24 object-cover">
              {%- endif -%}
            </a>

            <div class="flex flex-1 flex-col">
              <div class="flex justify-between gap-4">
                <div>
                  <a href="{{ item.url }}" class="text-sm font-medium text-gray-900 hover:text-brand">{{ item.product.title }}</a>
                  {%- unless item.product.has_only_default_variant -%}
                    <p class="mt-1 text-sm text-gray-500">{{ item.variant.title }}</p>
                  {%- endunless -%}
                </div>
                <p class="text-sm font-medium text-gray-900">{{ item.final_line_price | money }}</p>
              </div>

              <div class="mt-auto flex items-center justify-between">
                <input
                  type="number"
                  name="updates[]"
                  value="{{ item.quantity }}"
                  min="0"
                  aria-label="{{ 'cart.quantity' | t }}"
                  class="w-20 rounded-lg border border-gray-300 px-2 py-1 text-sm focus:border-brand focus:ring-brand"
                >
                <a href="{{ item.url_to_remove }}" class="text-sm text-gray-500 underline hover:text-red-600">{{ 'cart.remove' | t }}</a>
              </div>
            </div>
          </li>
        {%- endfor -%}
      </ul>

      <div class="flex flex-col items-end gap-4 border-t border-gray-200 pt-6">
        <div class="flex w-full items-center justify-between sm:w-auto sm:gap-12">
          <span class="text-base font-medium text-gray-900">{{ 'cart.subtotal' | t }}</span>
          <span class="text-base font-semibold text-gray-900">{{ cart.total_price | money }}</span>
        </div>
        <p class="text-sm text-gray-500">{{ 'cart.taxes_and_shipping_at_checkout' | t }}</p>

        <div class="flex w-full flex-col gap-3 sm:w-auto sm:flex-row">
          <button type="submit" name="update" class="rounded-lg border border-gray-300 px-6 py-3 text-sm font-semibold hover:bg-gray-50">
            {{ 'cart.title' | t }}
          </button>
          <button type="submit" name="checkout" class="rounded-lg bg-brand px-6 py-3 text-sm font-semibold text-white hover:bg-brand-dark">
            {{ 'cart.checkout' | t }}
          </button>
        </div>
      </div>
    {%- endform -%}
  {%- else -%}
    <div class="py-16 text-center">
      <p class="text-lg text-gray-500">{{ 'cart.empty' | t }}</p>
      <a href="{{ routes.all_products_collection_url }}" class="mt-6 inline-block rounded-lg bg-brand px-6 py-3 text-sm font-semibold text-white hover:bg-brand-dark">
        {{ 'cart.continue_shopping' | t }}
      </a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "settings": []
}
{% endschema %}
