<section class="mx-auto max-w-7xl px-4 py-10">
  <div class="grid grid-cols-1 gap-10 lg:grid-cols-2">
    {%- comment -%} Gallery {%- endcomment -%}
    <div class="flex flex-col gap-4">
      <div class="overflow-hidden rounded-xl bg-gray-100">
        {%- if product.featured_media -%}
          <img
            src="{{ product.featured_media | image_url: width: 1200 }}"
            alt="{{ product.featured_media.alt | escape }}"
            width="{{ product.featured_media.width }}"
            height="{{ product.featured_media.height }}"
            class="aspect-square w-full object-cover"
          >
        {%- else -%}
          <div class="flex aspect-square items-center justify-center text-gray-400">
            {{ 'product-1' | placeholder_svg_tag: 'h-1/2 w-1/2' }}
          </div>
        {%- endif -%}
      </div>

      {%- if product.media.size > 1 -%}
        <div class="grid grid-cols-4 gap-3">
          {%- for media in product.media limit: 4 -%}
            <div class="overflow-hidden rounded-lg bg-gray-100">
              <img
                src="{{ media | image_url: width: 300 }}"
                alt="{{ media.alt | escape }}"
                width="{{ media.preview_image.width }}"
                height="{{ media.preview_image.height }}"
                loading="lazy"
                class="aspect-square w-full object-cover"
              >
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Product info / buy form {%- endcomment -%}
    <div class="flex flex-col gap-6">
      <div>
        {%- if product.vendor != blank -%}
          <p class="text-sm font-medium uppercase tracking-wide text-gray-500">{{ product.vendor }}</p>
        {%- endif -%}
        <h1 class="mt-1 text-3xl font-bold tracking-tight text-gray-900">{{ product.title }}</h1>
        {% render 'price', product_or_variant: product.selected_or_first_available_variant, class: 'mt-4 text-lg' %}
      </div>

      {%- form 'product', product, class: 'flex flex-col gap-6' -%}
        {%- unless product.has_only_default_variant -%}
          <div class="flex flex-col gap-4">
            {%- for option in product.options_with_values -%}
              <div>
                <label class="block text-sm font-medium text-gray-900" for="Option-{{ option.position }}">{{ option.name }}</label>
                <select
                  id="Option-{{ option.position }}"
                  name="options[{{ option.name | escape }}]"
                  class="mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-brand focus:ring-brand"
                >
                  {%- for value in option.values -%}
                    <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                  {%- endfor -%}
                </select>
              </div>
            {%- endfor -%}
          </div>
        {%- endunless -%}

        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        <div class="flex items-center gap-4">
          <div class="flex flex-col gap-2">
            <label class="text-sm font-medium text-gray-900" for="Quantity">{{ 'products.product.quantity' | t }}</label>
            <input
              type="number"
              id="Quantity"
              name="quantity"
              value="1"
              min="1"
              class="w-24 rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-brand focus:ring-brand"
            >
          </div>
        </div>

        <button
          type="submit"
          name="add"
          {% unless product.available %}disabled{% endunless %}
          class="w-full rounded-lg bg-brand px-6 py-3 text-center text-sm font-semibold text-white transition-colors hover:bg-brand-dark disabled:cursor-not-allowed disabled:bg-gray-300"
        >
          {%- if product.available -%}
            {{ 'products.product.add_to_cart' | t }}
          {%- else -%}
            {{ 'products.product.sold_out' | t }}
          {%- endif -%}
        </button>
      {%- endform -%}

      {%- if product.description != blank -%}
        <div class="space-y-4 border-t border-gray-200 pt-6 text-sm leading-relaxed text-gray-700 [&_a]:text-brand [&_a]:underline [&_h2]:text-lg [&_h2]:font-semibold [&_ul]:list-disc [&_ul]:pl-5">
          {{ product.description }}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product information",
  "tag": "section",
  "settings": []
}
{% endschema %}
