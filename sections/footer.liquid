<footer class="mt-16 border-t border-gray-200 bg-gray-50">
  <div class="mx-auto max-w-7xl px-4 py-12">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <h2 class="text-lg font-semibold">{{ shop.name }}</h2>
        {%- if section.settings.description != blank -%}
          <p class="mt-3 text-sm text-gray-600">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' and block.settings.menu != blank -%}
          <div {{ block.shopify_attributes }}>
            <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-900">{{ block.settings.heading }}</h3>
            <ul class="mt-4 space-y-2">
              {%- for link in block.settings.menu.links -%}
                <li>
                  <a href="{{ link.url }}" class="text-sm text-gray-600 hover:text-brand">{{ link.title }}</a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="mt-10 flex flex-col items-center justify-between gap-4 border-t border-gray-200 pt-6 sm:flex-row">
      <p class="text-sm text-gray-500">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
      </p>

      <div class="flex items-center gap-4">
        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" class="text-gray-400 hover:text-brand" aria-label="Instagram">Instagram</a>
        {%- endif -%}
        {%- if settings.social_twitter_link != blank -%}
          <a href="{{ settings.social_twitter_link }}" class="text-gray-400 hover:text-brand" aria-label="X">X</a>
        {%- endif -%}
        {%- if settings.social_facebook_link != blank -%}
          <a href="{{ settings.social_facebook_link }}" class="text-gray-400 hover:text-brand" aria-label="Facebook">Facebook</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "A short sentence about your store."
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "menu" }
      ]
    }
  ]
}
{% endschema %}
