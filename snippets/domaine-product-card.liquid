{%- comment -%}
  Domaine product card.

  An interactive product card that lets a customer:
    - see an on-sale badge + markdown pricing when the variant is on sale,
    - click colour swatches to swap to that colour's imagery,
    - hover the card to reveal a secondary image for the selected variant,
    - read the brand (vendor), title, and pricing.

  Accepts:
    - product {Object} - the product to render (required)

  Usage:
    {% render 'domaine-product-card', product: product %}

  Interactivity is handled by the `<domaine-product-card>` web component in
  assets/domaine-product-card.js. The hover image-swap is pure Tailwind
  (group-hover), so no custom CSS is added — Tailwind remains the only stylesheet.

  IMAGE PAIRING ASSUMPTION
  ------------------------
  Each colour's PRIMARY image is the variant's featured image. Its SECONDARY
  (hover) image is taken as the NEXT image after it in the product's gallery
  (i.e. images are uploaded as front/back pairs per colour). To pair by alt text
  instead, change the two blocks marked `SECONDARY IMAGE` below.
{%- endcomment -%}

{%- liquid
  # Find the colour option (named "Color"/"Colour"); fall back to no swatches.
  assign color_option = null
  for opt in product.options_with_values
    assign opt_name = opt.name | downcase
    if opt_name contains 'color' or opt_name contains 'colour'
      assign color_option = opt
      break
    endif
  endfor

  assign has_colors = false
  if color_option and color_option.values.size > 0
    assign has_colors = true
    assign color_index = color_option.position | minus: 1
  endif

  # Initial state comes from the selected/first available variant.
  assign cv = product.selected_or_first_available_variant
  if has_colors
    assign initial_color = cv.options[color_index]
  endif

  assign init_primary = cv.featured_image | default: product.featured_image

  # SECONDARY IMAGE (initial): next image in the gallery after the primary.
  assign init_secondary = init_primary
  assign init_pos = init_primary.position
  if init_pos and init_pos < product.images.size
    assign init_secondary = product.images[init_pos]
  elsif product.images.size > 1
    assign init_secondary = product.images[1]
  endif

  assign init_on_sale = false
  if cv.compare_at_price and cv.compare_at_price > cv.price
    assign init_on_sale = true
  endif
-%}

<domaine-product-card class="group flex w-full max-w-[369px] flex-col gap-[15px] font-sans">
  {%- comment -%} ---- Image (primary + secondary crossfade on hover) ---- {%- endcomment -%}
  <a
    href="{{ cv.url | default: product.url }}"
    data-card-link
    class="relative block aspect-[315/340] overflow-hidden rounded-[10px] border border-[#E8E8E8] bg-white"
  >
    {%- if init_primary -%}
      <img
        data-primary-image
        src="{{ init_primary | image_url: width: 800 }}"
        srcset="{{ init_primary | image_url: width: 400 }} 400w, {{ init_primary | image_url: width: 800 }} 800w"
        sizes="(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 90vw"
        alt="{{ init_primary.alt | default: product.title | escape }}"
        width="{{ init_primary.width }}"
        height="{{ init_primary.height }}"
        loading="lazy"
        class="absolute inset-0 h-full w-full object-contain p-5 transition-opacity duration-300 group-hover:opacity-0"
      >
      <img
        data-secondary-image
        src="{{ init_secondary | image_url: width: 800 }}"
        alt=""
        aria-hidden="true"
        width="{{ init_secondary.width }}"
        height="{{ init_secondary.height }}"
        loading="lazy"
        class="absolute inset-0 h-full w-full object-contain p-5 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
      >
    {%- else -%}
      <div class="absolute inset-0 flex items-center justify-center text-gray-300">
        {{ 'product-1' | placeholder_svg_tag: 'h-1/2 w-1/2' }}
      </div>
    {%- endif -%}

    {%- comment -%} On-sale badge {%- endcomment -%}
    <span
      data-badge
      class="pointer-events-none absolute left-5 top-5 inline-flex items-center rounded-full border border-[#FF0000] px-3 py-1 text-[15px] leading-none text-[#FF0000] {% unless init_on_sale %}hidden{% endunless %}"
    >
      {{ 'products.product.on_sale' | t }}
    </span>
  </a>

  {%- comment -%} ---- Colour swatches ---- {%- endcomment -%}
  {%- if has_colors -%}
    <div class="flex flex-wrap items-center gap-[5px]" role="group" aria-label="{{ color_option.name | escape }}">
      {%- for value in color_option.values -%}
        {%- liquid
          capture value_name
            echo value
          endcapture

          # Representative variant for this colour.
          assign vx = value.variant
          if vx == nil
            for variant in product.variants
              if variant.options[color_index] == value_name
                assign vx = variant
                break
              endif
            endfor
          endif

          assign s_primary = vx.featured_image | default: product.featured_image

          # SECONDARY IMAGE (per colour): next image after the primary.
          assign s_secondary = s_primary
          assign s_pos = s_primary.position
          if s_pos and s_pos < product.images.size
            assign s_secondary = product.images[s_pos]
          elsif product.images.size > 1
            assign s_secondary = product.images[1]
          endif

          assign s_on_sale = false
          if vx.compare_at_price and vx.compare_at_price > vx.price
            assign s_on_sale = true
          endif

          assign swatch_color = value.swatch.color | default: value_name | downcase

          assign is_selected = false
          if value_name == initial_color
            assign is_selected = true
          endif
        -%}
        <button
          type="button"
          data-swatch
          data-color="{{ value_name | escape }}"
          data-url="{{ vx.url | default: product.url }}"
          data-primary="{{ s_primary | image_url: width: 800 }}"
          data-secondary="{{ s_secondary | image_url: width: 800 }}"
          data-price="{{ vx.price | money | escape }}"
          data-on-sale="{% if s_on_sale %}true{% else %}false{% endif %}"
          {% if s_on_sale %}data-compare="{{ vx.compare_at_price | money | escape }}"{% endif %}
          aria-label="{{ value_name | escape }}"
          aria-pressed="{% if is_selected %}true{% else %}false{% endif %}"
          title="{{ value_name | escape }}"
          style="background-color: {{ swatch_color }};"
          class="relative h-5 w-5 shrink-0 rounded-full {% if is_selected %}ring-1 ring-offset-2 ring-offset-white ring-[#0A4874]{% endif %}"
        >
          <span class="sr-only">{{ value_name }}</span>
        </button>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- comment -%} ---- Brand / title / price ---- {%- endcomment -%}
  <div class="flex flex-col gap-1.5">
    {%- if product.vendor != blank -%}
      <p class="text-sm leading-4 text-[#111111]">{{ product.vendor }}</p>
    {%- endif -%}

    <a href="{{ cv.url | default: product.url }}" data-card-link class="text-base font-medium leading-[18px] text-[#0A4874]">
      {{ product.title }}
    </a>

    <div data-price class="flex items-center gap-2 text-sm">
      {%- if init_on_sale -%}
        <s class="text-[#111111] line-through">{{ cv.compare_at_price | money }}</s>
        <span class="text-red-600">{{ cv.price | money }}</span>
      {%- else -%}
        <span class="text-[#111111]">{{ cv.price | money }}</span>
      {%- endif -%}
    </div>
  </div>
</domaine-product-card>

<script src="{{ 'domaine-product-card.js' | asset_url }}" defer></script>
