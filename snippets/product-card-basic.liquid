{%- comment -%}
  Basic product card (image, title, price).

  This is the simpler of the two card styles. It is selected when the theme
  setting "Product card style" is set to "Basic". The default style is the
  interactive Domaine card (snippets/domaine-product-card.liquid).

  Rendering is dispatched by snippets/product-card.liquid — sections always
  call `{% render 'product-card' %}` and the dispatcher picks the style.

  Accepts:
  - product {Object} - the product to render
{%- endcomment -%}

<article class="group relative flex flex-col">
  <a href="{{ product.url }}" class="block overflow-hidden rounded-lg bg-gray-100">
    {%- if product.featured_media -%}
      <img
        src="{{ product.featured_media | image_url: width: 600 }}"
        srcset="
          {{ product.featured_media | image_url: width: 300 }} 300w,
          {{ product.featured_media | image_url: width: 600 }} 600w,
          {{ product.featured_media | image_url: width: 900 }} 900w
        "
        sizes="(min-width: 1024px) 25vw, (min-width: 640px) 33vw, 50vw"
        alt="{{ product.featured_media.alt | escape }}"
        width="{{ product.featured_media.width }}"
        height="{{ product.featured_media.height }}"
        loading="lazy"
        class="aspect-square h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
      >
    {%- else -%}
      <div class="flex aspect-square items-center justify-center text-gray-400">
        {{ 'product-1' | placeholder_svg_tag: 'h-full w-full' }}
      </div>
    {%- endif -%}

    {%- unless product.available -%}
      <span class="absolute left-3 top-3 rounded bg-gray-900/80 px-2 py-1 text-xs font-medium text-white">
        {{ 'products.product.sold_out' | t }}
      </span>
    {%- endunless -%}
  </a>

  <div class="mt-3 flex flex-col gap-1">
    <h3 class="text-sm font-medium text-gray-900">
      <a href="{{ product.url }}">
        <span class="absolute inset-0" aria-hidden="true"></span>
        {{ product.title }}
      </a>
    </h3>
    {% render 'price', product_or_variant: product %}
  </div>
</article>
